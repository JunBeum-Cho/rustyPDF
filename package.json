{
  "name": "rustypdf",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "setup-pdfium": "node scripts/setup-pdfium.mjs",
    "icon": "tsx icon.ts",
    "build:mac": "tauri build --target universal-apple-darwin",
    "build:mac:intel": "tauri build --target x86_64-apple-darwin",
    "build:mac:arm": "tauri build --target aarch64-apple-darwin",
    "build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "build:windows:arm": "tauri build --target aarch64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "lucide-solid": "^1.11.0",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
